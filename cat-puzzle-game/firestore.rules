rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Validation for private user document
    function isValidUserDoc() {
      let data = request.resource.data;
      return data.uid is string
        && (data.displayName == null || data.displayName is string)
        && (data.photoURL == null || data.photoURL is string)
        && (data.email == null || data.email is string)
        // Scalable abuse limits
        && (data.completedLevels is int && data.completedLevels >= 0 && data.completedLevels <= 100000)
        && (data.totalStars is int && data.totalStars >= 0 && data.totalStars <= 300000)
        && (data.currentLevel is int && data.currentLevel >= 1 && data.currentLevel <= 100000)
        // Future economy systems placeholder validation
        && (data.coins == null || (data.coins is int && data.coins >= 0 && data.coins <= 10000000))
        && (data.themes == null || data.themes is list)
        && (data.items == null || data.items is list)
        && (data.guest is bool)
        && (data.profile == null || (
             data.profile.username is string 
             && data.profile.username.size() >= 3 
             && data.profile.username.size() <= 20
           ));
    }

    // Validation for public profile document
    function isValidPublicProfile() {
      let data = request.resource.data;
      return data.uid is string
        && (data.displayName == null || data.displayName is string)
        && (data.photoURL == null || data.photoURL is string)
        && (data.completedLevels is int && data.completedLevels >= 0 && data.completedLevels <= 100000)
        && (data.totalStars is int && data.totalStars >= 0 && data.totalStars <= 300000)
        && (data.currentLevel is int && data.currentLevel >= 1 && data.currentLevel <= 100000)
        && (data.guest is bool)
        && (data.profile == null || (
             data.profile.username is string 
             && data.profile.username.size() >= 3 
             && data.profile.username.size() <= 20
           ));
    }

    // Private user document: only owner can read and write
    match /users/{uid} {
      allow read, write: if isOwner(uid) && (request.method == 'delete' || isValidUserDoc());

      match /progress/game {
        allow read, write: if isOwner(uid)
          && (request.resource.data.currentLevel is int && request.resource.data.currentLevel >= 1 && request.resource.data.currentLevel <= 100000)
          && (request.resource.data.unlockedLevel is int && request.resource.data.unlockedLevel >= 1 && request.resource.data.unlockedLevel <= 100000);
      }
    }

    // Public leaderboard profiles: anyone authenticated can read, only owner can write
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if isOwner(uid) && (request.method == 'delete' || isValidPublicProfile());
    }
  }
}
